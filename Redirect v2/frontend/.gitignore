# Garagem Frontend - GitIgnore

# Arquivos de configuração local
config.local.js
.env.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Diretórios de dependências (se adicionar build tools)
node_modules/
bower_components/

# Cache
.cache/
.temp/
.tmp/

# Sistema operacional
.DS_Store
Thumbs.db
desktop.ini

# IDEs e Editores
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Build outputs (futuro)
dist/
build/
out/

# Uploads temporários
uploads/
temp-uploads/

# Backups
*.bak
*.backup

# Service worker cache
sw.js
workbox-*.js

